{
  "name": "opaltrace",
  "version": "2.0.0",
  "description": "OpalTrace — Plataforma de trazabilidad minera responsable by MINEX",
  "author": "MINEX Development Team",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "server": "json-server --watch server/db.json --routes server/routes.json --port 3000",
    "deploy": "ng build --base-href /OpalTrace-webapp/ && npx angular-cli-ghpages --dir=dist/opaltrace/browser"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.21",
    "angular-cli-ghpages": "^3.0.3",
    "baseline-browser-mapping": "^2.10.23",
    "jasmine-core": "~5.9.0",
    "json-server": "^0.17.4",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
